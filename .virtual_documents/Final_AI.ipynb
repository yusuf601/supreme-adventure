print(f"\n✅ CELL INF-1 selesai — {len(data_baru_1row)} file inference berhasil dimuat.")
 


all_features_inf = []
 
for komoditas in komoditas_training:
    df_lama    = final_data[komoditas]          # seri training (sudah bersih)
    df_row_baru = data_baru_1row[komoditas]     # 1 baris baru
 
    # Gabung: seri lama + 1 baris baru, sort by Date
    df_extended = pl.concat([df_lama, df_row_baru]).sort("Date")
 
    prov_features = []
    prov_columns  = [c for c in df_extended.columns if c != "Date"]
 
    for prov in prov_columns:
        s = df_extended.get_column(prov).drop_nulls()
 
        # 4 fitur "The Dream Team" — identik dengan training
        mean_val = s.mean()
        std_val  = s.std()
        cv       = std_val / mean_val if mean_val != 0 else 0
        kurt     = s.kurtosis()
 
        autocorr = (
            pl.DataFrame({"asli": s, "lag": s.shift(1)})
            .drop_nulls()
            .select(pl.corr("asli", "lag"))
            .item()
        )
 
        # Trend: sekarang s[-1] adalah harga hari baru (titik paling akhir)
        trend = (s[-1] - s[0]) / s[0] if s[0] != 0 else 0
 
        prov_features.append({
            "Provinsi"             : prov,
            f"{komoditas}_CV"      : cv,
            f"{komoditas}_Kurtosis": kurt,
            f"{komoditas}_Lag1"    : autocorr,
            f"{komoditas}_Trend"   : trend,
        })
 
    all_features_inf.append(pl.DataFrame(prov_features))
 
