}).with_columns(
    pl.when(pl.col("Cluster_KMeans") == 0)
      .then(pl.lit("Zona Ketahanan Harga Stabil"))
      .otherwise(pl.lit("Zona Rentan Gejolak Ekstrem"))
      .alias("Status_KMeans")
)
 
# --- Fuzzy C-Means (pakai centroid cntr dari training) ---
m           = 2.0
results_fcm = []
 
for i, prov in enumerate(provinsi_inf_list):
    x     = data_scaled_inf[i]
    dists = np.linalg.norm(cntr - x, axis=1)
    dists = np.where(dists == 0, 1e-10, dists)
    power = 2.0 / (m - 1)
    u     = 1.0 / np.sum((dists[:, None] / dists[None, :]) ** power, axis=1)
    cluster = int(np.argmax(u))
 
    results_fcm.append({
        "Provinsi"     : prov,
        "Cluster_FCM"  : cluster,
        "Membership_C0": round(float(u[0]), 4),
        "Membership_C1": round(float(u[1]), 4),
        "Status_FCM"   : (
            "Zona Ketahanan Harga Stabil"
            if cluster == 0 else
            "Zona Rentan Gejolak Ekstrem"
        ),
    })
 
df_hasil_fcm = pl.DataFrame(results_fcm)
 
# Gabung semua hasil
df_hasil_final = df_hasil_kmeans.join(
